# Copy to .env and fill in. NEVER commit the real .env — it's in .gitignore.
# This file is loaded by Claude Code when it starts MCP servers referenced in .mcp.json.

# ─────────────────────────────────────────────────────────────────────────────
# Existing SEO agent (see SETUP.md)
# ─────────────────────────────────────────────────────────────────────────────
BRAVE_API_KEY=
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Meta Ads — shared across all clients (your Meta developer app)
# Create at https://developers.facebook.com/apps/ → type "Business"
# Add Marketing API product. Permissions needed: ads_management, ads_read,
# business_management. For production requesting "ads_management" requires
# App Review unless you're the app admin using a system-user token.
# ─────────────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Meta Ads — per-client system-user token
# Generate in Business Manager → Business Settings → System Users → [Create]
# → grant access to the client's Ad Account + Page → Generate New Token →
# select your app → pick permissions (ads_management, ads_read, business_management)
# → copy token (no expiry). Use one token per client BM.
# ─────────────────────────────────────────────────────────────────────────────
TPZ_META_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Google Ads — shared developer app (one for all clients)
# DEVELOPER_TOKEN: Google Ads → Tools → API Center (start with Test/Basic
# access, request Standard later — takes 1–3 weeks).
# CLIENT_ID + CLIENT_SECRET: Google Cloud Console → create OAuth 2.0 Client
# (Desktop app). Enable Google Ads API on the project.
# REFRESH_TOKEN: generate by running the auth bootstrap script
# (see docs/ADS-MCP-SETUP.md). Use the Google account that has MCC access
# for the OAuth consent flow.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Google Ads — per-client customer ID (10-digit, no dashes)
# This is the "login customer ID" — the client account you want to manage
# through the MCC. Find in Google Ads UI top-right next to the account name.
# Example: 123-456-7890 → 1234567890
# ─────────────────────────────────────────────────────────────────────────────
TPZ_GOOGLE_ADS_CUSTOMER_ID=
